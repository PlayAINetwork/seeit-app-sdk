# Port the Express server listens on (serves the webview + API + webhook).
# Defaults to 4000 to avoid clashing with the SeeIt backend on 3000.
PORT=4000

# Your app's ID from the SeeIt developer console. Tokens must carry this as
# their `aud`, so verification rejects tokens minted for any other app.
SEEIT_APP_ID=00000000-0000-0000-0000-000000000000

# Where to fetch SeeIt's public keys to verify launch/session tokens.
# Point this at the SeeIt backend that minted them.
#   local dev: http://localhost:3000/glass/.well-known/jwks.json
SEEIT_JWKS_URL=http://localhost:3000/glass/.well-known/jwks.json

# Optional: if you set a webhook secret in the developer console, set the same
# value here to enable HMAC signature verification on incoming webhooks.
# WEBHOOK_SECRET=
