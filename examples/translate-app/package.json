{
  "name": "glass-translate-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Example SeeIt Glass app: live speech translation in a React webview",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "bun src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@seeit/app-sdk": "github:PlayAINetwork/seeit-app-sdk",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "trustedDependencies": [
    "@seeit/app-sdk"
  ],
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
