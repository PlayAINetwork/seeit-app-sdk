{
  "name": "@seeit/glass-sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for building apps on the SeeIt Glass platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@livekit/rtc-node": "^0.13.0",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["seeit", "glass", "livekit", "sdk", "ar", "wearable"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
