{
  "name": "@seeit/app-sdk",
  "version": "1.0.0",
  "description": "Node.js SDK for building apps on the SeeIt App platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12"
  },
  "keywords": [
    "seeit",
    "app",
    "sdk",
    "ar",
    "wearable"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
